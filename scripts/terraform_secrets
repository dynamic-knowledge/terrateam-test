#!/usr/bin/env bash
# Sourced by Terrateam workflow env step (method: source).
# Values come from GitHub repo secrets via SECRETS_CONTEXT in terrateam.yml.
#
# Use ${VAR:-} so missing secrets export as empty strings. Terrateam's source
# wrapper runs with "set -u"; bare $VAR references fail when a secret is unset.

export AKUITY_API_KEY_ID="${AKUITY_API_KEY_ID:-}"
export AKUITY_API_KEY_SECRET="${AKUITY_API_KEY_SECRET:-}"
export SNOWFLAKE_USER="${SNOWFLAKE_USER:-}"
export SNOWFLAKE_PASSWORD="${SNOWFLAKE_PASSWORD:-}"
export TF_VAR_snowflake_user="${SNOWFLAKE_USER:-}"
export TF_VAR_snowflake_password="${SNOWFLAKE_PASSWORD:-}"
export TF_VAR_fivetran_api_key="${FIVETRAN_API_KEY:-}"
export TF_VAR_fivetran_api_secret="${FIVETRAN_API_SECRET:-}"
export TF_VAR_dreamdata_external_id="${DREAMDATA_EXTERNAL_ID:-}"
export TF_VAR_dreamdata_snowflake_integration_external_id="${SNOWFLAKE_AWS_EXTERNAL_ID:-}"
export TF_VAR_datadog_api_key="${DATADOG_API_KEY:-}"
export TF_VAR_datadog_app_key="${DATADOG_APP_KEY:-}"
